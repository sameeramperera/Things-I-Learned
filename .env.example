# Copy this file to .env.local (which is gitignored) and fill in real values.

# Password required to log into /admin and add new notes.
ADMIN_PASSWORD=change-me

# Random secret used to sign the admin session cookie. Generate one with:
#   openssl rand -hex 32
ADMIN_SESSION_SECRET=change-me-too

# Optional. When set, the admin "add note" API commits the new .mdx file to
# GitHub via the Contents API instead of writing to local disk. Required in
# production, since the deployed filesystem is read-only/ephemeral.
# Personal access token with "Contents: Read and write" on the repo below.
GITHUB_TOKEN=
# owner/repo, e.g. sameeramperera/Things-I-Learned
GITHUB_REPO=
# Defaults to "main" if unset.
GITHUB_BRANCH=
